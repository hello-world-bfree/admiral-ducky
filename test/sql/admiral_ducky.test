# name: test/sql/admiral_ducky.test
# description: test admiral_ducky extension
# group: [ducky]

# Require statement will ensure the extension is loaded from now on
require admiral_ducky

require icu

# Test that s3_transform scalar function exists (will error without valid S3 path/credentials)
statement error
SELECT s3_transform('invalid_path');
----
S3 path must start with s3://

# Test s3_transform_with function exists with invalid path
statement error
SELECT s3_transform_with('invalid_path', 'trim');
----
S3 path must start with s3://

# Test s3_transform with valid S3 path format (expected to fail fetching)
statement error
SELECT s3_transform('s3://test-bucket/test.txt');
----
Failed to fetch S3 object

# Test s3_transform_script function exists with invalid path
statement error
SELECT s3_transform_script('invalid_path', 'text.to_upper()');
----
S3 path must start with s3://

# Test s3_transform_script with valid S3 path format (expected to fail fetching)
statement error
SELECT s3_transform_script('s3://test-bucket/test.txt', 'text.to_upper()');
----
Failed to fetch S3 object

# Test s3_fetch function exists with invalid path
statement error
SELECT s3_fetch('invalid_path');
----
S3 path must start with s3://

# Test s3_fetch with valid S3 path format (expected to fail fetching)
statement error
SELECT s3_fetch('s3://test-bucket/test.txt');
----
Failed to fetch S3 object

# Test s3_put function exists with invalid path
statement error
SELECT s3_put('invalid_path', 'content');
----
S3 path must start with s3://

# Test s3_put with valid S3 path format (expected to fail without credentials)
statement error
SELECT s3_put('s3://test-bucket/test.txt', 'hello world');
----
Failed to put S3 object

# Test rhai function works standalone (no S3 needed)
query I
SELECT rhai('hello world', 'text.to_upper()');
----
HELLO WORLD

# Test rhai with squeeze_whitespace
query I
SELECT rhai('hello    world', 'squeeze_whitespace(text)');
----
hello world

# Test rhai with regex_replace
query I
SELECT rhai('hello 123 world', 'regex_replace(text, "[0-9]+", "NUM")');
----
hello NUM world

# Test rhai with truncate
query I
SELECT rhai('hello world', 'truncate(text, 5)');
----
hello

# Test rhai with identity transform (just return text)
query I
SELECT rhai('unchanged', 'text');
----
unchanged

# Test embed_fake with single row (verifies list vector write path)
query I
SELECT length(embed_fake('hello world', 768));
----
768

# Test embed_fake with multiple rows (verifies batched list vector output)
query I
SELECT length(embed_fake(t.text, 384)) FROM (VALUES ('hello'), ('world'), ('test'), ('embed'), ('fake')) AS t(text);
----
384
384
384
384
384

# Test embed_fake with larger batch (verifies list vector reserve/write at scale)
query I
SELECT count(*) FROM (SELECT embed_fake('row ' || i::varchar, 768) FROM generate_series(1, 100) AS s(i));
----
100

# Test embed function exists (expected to fail connecting without running server)
statement error
SELECT embed('test text', 'http://127.0.0.1:59999');
----
Failed to connect

# Test embed with NULL text does not crash
query I
SELECT embed(NULL, 'http://127.0.0.1:59999');
----
NULL

# Test embed error path does not double-free on batch with mixed results
statement error
SELECT embed(t.text, 'http://127.0.0.1:59999') FROM (VALUES ('hello'), ('world'), ('foo')) AS t(text);
----
Failed to connect

# Test embed error on single row does not corrupt memory
statement error
SELECT embed('some long text that would need embedding', 'http://127.0.0.1:59999');
----
Failed to connect

# Test token_count with unreachable endpoint
statement error
SELECT token_count('test text', 'http://127.0.0.1:59999');
----
Failed to connect

# Test token_count with NULL text does not crash
query I
SELECT token_count(NULL, 'http://127.0.0.1:59999');
----
NULL

# Test chunk_text with unreachable endpoint (error before list vector allocation)
statement error
SELECT chunk_text('test text', 512, 'http://127.0.0.1:59999');
----
Failed to connect

# Test chunk_text with NULL text does not crash
query I
SELECT chunk_text(NULL, 512, 'http://127.0.0.1:59999');
----
NULL

# Test chunk_text error path on multi-row input does not double-free
statement error
SELECT chunk_text(t.text, 512, 'http://127.0.0.1:59999') FROM (VALUES ('hello'), ('world')) AS t(text);
----
Failed to connect

# Test http_post function exists with unreachable endpoint
statement error
SELECT http_post('http://127.0.0.1:59999/post', '{"test": true}');
----
error sending request

# Test http_post with invalid headers JSON
statement error
SELECT http_post('http://127.0.0.1:59999/post', '{}', 'not valid json');
----
Invalid headers JSON

# Test http_post_rhai function exists with unreachable endpoint
statement error
SELECT http_post_rhai('http://127.0.0.1:59999/post', 'hello', 'text.to_upper()');
----
error sending request

# Test http_post_rhai with invalid Rhai script
statement error
SELECT http_post_rhai('http://127.0.0.1:59999/post', 'hello', 'invalid syntax +++');
----
Script compilation error

# Test http_post_batch function exists with invalid payloads JSON
statement error
SELECT * FROM http_post_batch('http://127.0.0.1:59999/post', 'not valid json', '10', '');
----
Invalid payloads JSON

# Test http_post_batch with batch_size of 0
statement error
SELECT * FROM http_post_batch('http://127.0.0.1:59999/post', '["a", "b"]', '0', '');
----
batch_size must be greater than 0

# Test http_post_batch with invalid batch_size
statement error
SELECT * FROM http_post_batch('http://127.0.0.1:59999/post', '["a"]', 'not_a_number', '');
----
Invalid batch_size

# admiral_ducky_functions returns the catalog
query I
SELECT count(*) >= 16 FROM admiral_ducky_functions();
----
true

# Specific function present
query I
SELECT count(*) FROM admiral_ducky_functions() WHERE name = 's3_fetch';
----
1

# Both kinds populated
query II
SELECT
  (SELECT count(*) FROM admiral_ducky_functions() WHERE kind = 'scalar') > 0,
  (SELECT count(*) FROM admiral_ducky_functions() WHERE kind = 'table') > 0;
----
true	true

# Every row has an example
query I
SELECT count(*) FROM admiral_ducky_functions() WHERE example IS NULL OR example = '';
----
0

# Every row has a category
query I
SELECT count(*) FROM admiral_ducky_functions() WHERE category IS NULL OR category = '';
----
0

# html_extract correctly tagged as table function
query II
SELECT name, kind FROM admiral_ducky_functions() WHERE name = 'html_extract';
----
html_extract	table

# Comment discipline: every infra-bound row's example carries a -- requires comment
# (embed_fake lives in the embed module but runs without infra)
query I
SELECT count(*) FROM admiral_ducky_functions()
WHERE module IN ('s3','http','embed')
  AND name <> 'embed_fake'
  AND example NOT LIKE '%-- requires%';
----
0

# Drift check A: every name in the catalog exists in duckdb_functions()
query I
SELECT count(*) FROM admiral_ducky_functions() af
WHERE af.name NOT IN (SELECT function_name FROM duckdb_functions());
----
0

# Drift check B: every registered admiral_ducky function appears in the catalog
query I
SELECT count(*) FROM duckdb_functions()
WHERE function_name IN (
    's3_fetch','s3_put','s3_exists','s3_transform','s3_transform_with','s3_transform_script',
    'http_post','http_post_rhai','http_post_batch',
    'rhai','embed','embed_fake','token_count','chunk_text','is_english','html_extract'
)
AND function_name NOT IN (SELECT name FROM admiral_ducky_functions());
----
0
